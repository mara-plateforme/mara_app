generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "../node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Application {
  id                String   @id @default(cuid())
  fullName         String
  email            String
  phone            String
  country          String
  educationLevel   String
  currentField     String?
  desiredProgram   String
  campus           String
  motivation       String
  experience       String?
  projets          String?
  availability     String
  financialSituation String
  hasLaptop        Boolean
  foundAboutUs     String
  status           String   @default("pending") // pending, accepted, rejected
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("applications")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
}
